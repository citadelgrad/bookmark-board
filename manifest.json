{
  "manifest_version": 3,
  "name": "Bookmark Board",
  "version": "1.0.0",
  "description": "New tab bookmark manager",
  "permissions": ["bookmarks", "tabs", "storage", "favicon", "alarms", "downloads"],
  "background": { "service_worker": "background.js" },
  "chrome_url_overrides": {
    "newtab": "newtab.html"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
